// =============================================================================
// kobuki_driver_node.cpp — Lifecycle driver for real Kobuki base (ROS 2 Jazzy)
//
// Communicates with the Kobuki via USB serial using the Kobuki protocol.
// Publishes odometry, joint states, TF, bumper/cliff events.
// Subscribes to cmd_vel for velocity commands.
// =============================================================================
#include <chrono>
#include <cmath>
#include <memory>
#include <string>

#include <rclcpp/rclcpp.hpp>
#include <rclcpp_lifecycle/lifecycle_node.hpp>
#include <lifecycle_msgs/msg/state.hpp>
#include <geometry_msgs/msg/twist.hpp>
#include <geometry_msgs/msg/transform_stamped.hpp>
#include <nav_msgs/msg/odometry.hpp>
#include <sensor_msgs/msg/joint_state.hpp>
#include <tf2_ros/transform_broadcaster.h>
#include <tf2/LinearMath/Quaternion.h>

#include "patrick_navigation/kobuki_protocol.hpp"
#include "patrick_msgs/msg/bumper_event.hpp"
#include "patrick_msgs/msg/cliff_event.hpp"

using CallbackReturn = rclcpp_lifecycle::node_interfaces::LifecycleNodeInterface::CallbackReturn;
using namespace std::chrono_literals;

class KobukiDriverNode : public rclcpp_lifecycle::LifecycleNode
{
public:
  explicit KobukiDriverNode(const rclcpp::NodeOptions & opts = rclcpp::NodeOptions())
  : rclcpp_lifecycle::LifecycleNode("kobuki_driver_node", opts)
  {
    declare_parameter("serial_port", "/dev/ttyUSB0");
    declare_parameter("wheel_separation", 0.230);
    declare_parameter("wheel_radius", 0.035);
    declare_parameter("cmd_vel_timeout", 0.6);
    declare_parameter("use_imu_heading", true);
    declare_parameter("publish_tf", true);
    declare_parameter("update_rate", 50.0);
    declare_parameter("cmd_vel_topic", "/diff_drive_controller/cmd_vel_unstamped");
    declare_parameter("odom_topic", "/diff_drive_controller/odom");
    declare_parameter("odom_frame", "odom");
    declare_parameter("base_frame", "base_footprint");
  }

  // ── on_configure ──────────────────────────────────────────────────────────
  CallbackReturn on_configure(const rclcpp_lifecycle::State &) override
  {
    RCLCPP_INFO(get_logger(), "Configuring KobukiDriverNode");

    serial_port_name_ = get_parameter("serial_port").as_string();
    wheel_separation_ = get_parameter("wheel_separation").as_double();
    wheel_radius_     = get_parameter("wheel_radius").as_double();
    cmd_vel_timeout_  = get_parameter("cmd_vel_timeout").as_double();
    use_imu_heading_  = get_parameter("use_imu_heading").as_bool();
    publish_tf_       = get_parameter("publish_tf").as_bool();
    update_rate_      = get_parameter("update_rate").as_double();
    auto cmd_vel_topic = get_parameter("cmd_vel_topic").as_string();
    auto odom_topic    = get_parameter("odom_topic").as_string();
    odom_frame_        = get_parameter("odom_frame").as_string();
    base_frame_        = get_parameter("base_frame").as_string();

    // Publishers
    odom_pub_  = create_publisher<nav_msgs::msg::Odometry>(odom_topic, 10);
    js_pub_    = create_publisher<sensor_msgs::msg::JointState>("/joint_states", 10);
    bump_pub_  = create_publisher<patrick_msgs::msg::BumperEvent>("events/bumper", 10);
    cliff_pub_ = create_publisher<patrick_msgs::msg::CliffEvent>("events/cliff", 10);

    // Subscriber
    cmd_vel_sub_ = create_subscription<geometry_msgs::msg::Twist>(
      cmd_vel_topic, 10,
      [this](geometry_msgs::msg::Twist::SharedPtr msg) {
        last_cmd_ = *msg;
        last_cmd_time_ = now();
      });

    // TF broadcaster
    tf_broadcaster_ = std::make_unique<tf2_ros::TransformBroadcaster>(*this);

    // Reset odometry state
    x_ = y_ = theta_ = 0.0;
    left_wheel_pos_ = right_wheel_pos_ = 0.0;
    prev_left_encoder_ = prev_right_encoder_ = 0;
    first_encoder_ = true;
    prev_bumper_ = prev_cliff_ = 0;

    RCLCPP_INFO(get_logger(), "Configured: port=%s, rate=%.0f Hz",
                serial_port_name_.c_str(), update_rate_);
    return CallbackReturn::SUCCESS;
  }

  // ── on_activate ───────────────────────────────────────────────────────────
  CallbackReturn on_activate(const rclcpp_lifecycle::State &) override
  {
    RCLCPP_INFO(get_logger(), "Activating KobukiDriverNode — opening %s",
                serial_port_name_.c_str());

    if (!serial_.open_port(serial_port_name_)) {
      RCLCPP_ERROR(get_logger(), "Failed to open serial port: %s", serial_port_name_.c_str());
      return CallbackReturn::FAILURE;
    }

    // Start the update timer
    auto period = std::chrono::duration<double>(1.0 / update_rate_);
    timer_ = create_wall_timer(
      std::chrono::duration_cast<std::chrono::nanoseconds>(period),
      [this]() { update(); });

    RCLCPP_INFO(get_logger(), "KobukiDriverNode active");
    return CallbackReturn::SUCCESS;
  }

  // ── on_deactivate ─────────────────────────────────────────────────────────
  CallbackReturn on_deactivate(const rclcpp_lifecycle::State &) override
  {
    RCLCPP_INFO(get_logger(), "Deactivating KobukiDriverNode");

    // Send zero velocity before closing
    auto stop = kobuki::CommandBuilder::base_control(0.0, 0.0);
    serial_.write_bytes(stop.data(), stop.size());

    timer_.reset();
    serial_.close_port();

    return CallbackReturn::SUCCESS;
  }

  // ── on_cleanup ────────────────────────────────────────────────────────────
  CallbackReturn on_cleanup(const rclcpp_lifecycle::State &) override
  {
    RCLCPP_INFO(get_logger(), "Cleaning up KobukiDriverNode");
    odom_pub_.reset();
    js_pub_.reset();
    bump_pub_.reset();
    cliff_pub_.reset();
    cmd_vel_sub_.reset();
    tf_broadcaster_.reset();
    return CallbackReturn::SUCCESS;
  }

  // ── on_shutdown ───────────────────────────────────────────────────────────
  CallbackReturn on_shutdown(const rclcpp_lifecycle::State & state) override
  {
    RCLCPP_INFO(get_logger(), "Shutting down KobukiDriverNode");
    if (state.id() == lifecycle_msgs::msg::State::PRIMARY_STATE_ACTIVE) {
      on_deactivate(state);
    }
    return CallbackReturn::SUCCESS;
  }

private:
  // ── Main update loop (called at update_rate_ Hz) ──────────────────────────
  void update()
  {
    // 1. Read serial data
    uint8_t buf[256];
    int n = serial_.read_bytes(buf, sizeof(buf));
    bool got_feedback = false;
    if (n > 0) {
      got_feedback = parser_.feed(buf, static_cast<size_t>(n));
    }

    // 2. Send velocity command (or zero if timeout)
    double elapsed = (now() - last_cmd_time_).seconds();
    double cmd_lin = last_cmd_.linear.x;
    double cmd_ang = last_cmd_.angular.z;
    if (elapsed > cmd_vel_timeout_) {
      cmd_lin = 0.0;
      cmd_ang = 0.0;
    }
    auto pkt = kobuki::CommandBuilder::base_control(cmd_lin, cmd_ang);
    serial_.write_bytes(pkt.data(), pkt.size());

    // 3. Process feedback
    if (got_feedback) {
      const auto & fb = parser_.feedback();
      auto stamp = now();

      if (fb.has_basic) {
        process_odometry(fb, stamp);
        process_events(fb, stamp);
        publish_joint_states(stamp);

        // Battery warning
        double voltage = fb.basic.battery * 0.1;
        if (voltage < 14.0 && voltage > 0.0) {
          RCLCPP_WARN_THROTTLE(get_logger(), *get_clock(), 30000,
            "Kobuki battery low: %.1f V", voltage);
        }
      }
    }
  }

  // ── Odometry computation from encoder ticks ───────────────────────────────
  void process_odometry(const kobuki::KobukiFeedback & fb, const rclcpp::Time & stamp)
  {
    uint16_t left_enc  = fb.basic.left_encoder;
    uint16_t right_enc = fb.basic.right_encoder;

    if (first_encoder_) {
      prev_left_encoder_  = left_enc;
      prev_right_encoder_ = right_enc;
      first_encoder_ = false;
      prev_stamp_ = stamp;
      return;
    }

    // Encoder deltas → distance
    int16_t d_left  = kobuki::encoder_delta(left_enc, prev_left_encoder_);
    int16_t d_right = kobuki::encoder_delta(right_enc, prev_right_encoder_);
    prev_left_encoder_  = left_enc;
    prev_right_encoder_ = right_enc;

    double dist_left  = d_left * kobuki::TICK_TO_RAD * wheel_radius_;
    double dist_right = d_right * kobuki::TICK_TO_RAD * wheel_radius_;

    // Accumulate wheel positions (for joint states)
    left_wheel_pos_  += d_left * kobuki::TICK_TO_RAD;
    right_wheel_pos_ += d_right * kobuki::TICK_TO_RAD;

    // Differential drive kinematics
    double dt = (stamp - prev_stamp_).seconds();
    prev_stamp_ = stamp;
    if (dt <= 0.0) return;

    double d_center = (dist_left + dist_right) / 2.0;
    double d_theta  = (dist_right - dist_left) / wheel_separation_;

    // Optionally use IMU gyro for heading
    if (use_imu_heading_ && fb.has_inertial) {
      // Gyro angle is in hundredths of degree, convert to radians
      double gyro_heading = fb.inertial.angle * M_PI / 18000.0;
      // Use gyro for heading directly (more accurate than wheel-only)
      theta_ = gyro_heading;
    } else {
      theta_ += d_theta;
    }

    // Wrap theta to [-pi, pi]
    while (theta_ >  M_PI) theta_ -= 2.0 * M_PI;
    while (theta_ < -M_PI) theta_ += 2.0 * M_PI;

    // Update position
    x_ += d_center * std::cos(theta_);
    y_ += d_center * std::sin(theta_);

    // Velocities
    double v_linear  = d_center / dt;
    double v_angular = d_theta / dt;

    // Publish odometry
    nav_msgs::msg::Odometry odom;
    odom.header.stamp = stamp;
    odom.header.frame_id = odom_frame_;
    odom.child_frame_id  = base_frame_;

    odom.pose.pose.position.x = x_;
    odom.pose.pose.position.y = y_;
    odom.pose.pose.position.z = 0.0;

    tf2::Quaternion q;
    q.setRPY(0.0, 0.0, theta_);
    odom.pose.pose.orientation.x = q.x();
    odom.pose.pose.orientation.y = q.y();
    odom.pose.pose.orientation.z = q.z();
    odom.pose.pose.orientation.w = q.w();

    // Covariance (diagonal)
    odom.pose.covariance[0]  = 0.1;   // x
    odom.pose.covariance[7]  = 0.1;   // y
    odom.pose.covariance[35] = 0.05;  // yaw

    odom.twist.twist.linear.x  = v_linear;
    odom.twist.twist.angular.z = v_angular;
    odom.twist.covariance[0]  = 0.1;
    odom.twist.covariance[7]  = 0.1;
    odom.twist.covariance[35] = 0.05;

    odom_pub_->publish(odom);

    // Publish TF
    if (publish_tf_) {
      geometry_msgs::msg::TransformStamped tf;
      tf.header.stamp = stamp;
      tf.header.frame_id = odom_frame_;
      tf.child_frame_id  = base_frame_;
      tf.transform.translation.x = x_;
      tf.transform.translation.y = y_;
      tf.transform.translation.z = 0.0;
      tf.transform.rotation = odom.pose.pose.orientation;
      tf_broadcaster_->sendTransform(tf);
    }
  }

  // ── Bumper / cliff event publishing ──────────────────────────────────────
  void process_events(const kobuki::KobukiFeedback & fb, const rclcpp::Time & /*stamp*/)
  {
    uint8_t bumper = fb.basic.bumper;
    uint8_t cliff  = fb.basic.cliff;

    // Publish bumper events on state change
    if (bumper != prev_bumper_) {
      auto check_bumper = [&](uint8_t mask, uint8_t id) {
        bool was = (prev_bumper_ & mask) != 0;
        bool is  = (bumper & mask) != 0;
        if (was != is) {
          patrick_msgs::msg::BumperEvent msg;
          msg.bumper = id;
          msg.state = is ? patrick_msgs::msg::BumperEvent::PRESSED
                         : patrick_msgs::msg::BumperEvent::RELEASED;
          bump_pub_->publish(msg);
        }
      };
      check_bumper(kobuki::BUMPER_LEFT,   patrick_msgs::msg::BumperEvent::LEFT);
      check_bumper(kobuki::BUMPER_CENTER, patrick_msgs::msg::BumperEvent::CENTER);
      check_bumper(kobuki::BUMPER_RIGHT,  patrick_msgs::msg::BumperEvent::RIGHT);
      prev_bumper_ = bumper;
    }

    // Publish cliff events on state change
    if (cliff != prev_cliff_) {
      auto check_cliff = [&](uint8_t mask, uint8_t id) {
        bool was = (prev_cliff_ & mask) != 0;
        bool is  = (cliff & mask) != 0;
        if (was != is) {
          patrick_msgs::msg::CliffEvent msg;
          msg.sensor = id;
          msg.state = is ? patrick_msgs::msg::CliffEvent::CLIFF
                         : patrick_msgs::msg::CliffEvent::FLOOR;
          if (fb.has_cliff) {
            msg.bottom = fb.cliff.bottom[id];
          }
          cliff_pub_->publish(msg);
        }
      };
      check_cliff(kobuki::CLIFF_RIGHT,  0);
      check_cliff(kobuki::CLIFF_CENTER, 1);
      check_cliff(kobuki::CLIFF_LEFT,   2);
      prev_cliff_ = cliff;
    }
  }

  // ── Joint state publishing (wheel encoders) ──────────────────────────────
  void publish_joint_states(const rclcpp::Time & stamp)
  {
    sensor_msgs::msg::JointState js;
    js.header.stamp = stamp;
    js.name     = {"wheel_left_joint", "wheel_right_joint"};
    js.position = {left_wheel_pos_, right_wheel_pos_};
    js_pub_->publish(js);
  }

  // ── Members ──────────────────────────────────────────────────────────────
  // Config
  std::string serial_port_name_;
  double wheel_separation_ = 0.230;
  double wheel_radius_     = 0.035;
  double cmd_vel_timeout_  = 0.6;
  bool   use_imu_heading_  = true;
  bool   publish_tf_       = true;
  double update_rate_      = 50.0;
  std::string odom_frame_  = "odom";
  std::string base_frame_  = "base_footprint";

  // Serial & protocol
  kobuki::SerialPort serial_;
  kobuki::PacketParser parser_;

  // ROS interfaces
  rclcpp::Publisher<nav_msgs::msg::Odometry>::SharedPtr            odom_pub_;
  rclcpp::Publisher<sensor_msgs::msg::JointState>::SharedPtr       js_pub_;
  rclcpp::Publisher<patrick_msgs::msg::BumperEvent>::SharedPtr     bump_pub_;
  rclcpp::Publisher<patrick_msgs::msg::CliffEvent>::SharedPtr      cliff_pub_;
  rclcpp::Subscription<geometry_msgs::msg::Twist>::SharedPtr       cmd_vel_sub_;
  std::unique_ptr<tf2_ros::TransformBroadcaster>                   tf_broadcaster_;
  rclcpp::TimerBase::SharedPtr                                     timer_;

  // Command state
  geometry_msgs::msg::Twist last_cmd_;
  rclcpp::Time last_cmd_time_{0, 0, RCL_ROS_TIME};

  // Odometry state
  double x_ = 0.0, y_ = 0.0, theta_ = 0.0;
  double left_wheel_pos_ = 0.0, right_wheel_pos_ = 0.0;
  uint16_t prev_left_encoder_ = 0, prev_right_encoder_ = 0;
  bool first_encoder_ = true;
  rclcpp::Time prev_stamp_{0, 0, RCL_ROS_TIME};

  // Event state (for edge detection)
  uint8_t prev_bumper_ = 0;
  uint8_t prev_cliff_  = 0;
};

// ── main ───────────────────────────────────────────────────────────────────
int main(int argc, char * argv[])
{
  rclcpp::init(argc, argv);
  auto node = std::make_shared<KobukiDriverNode>();
  rclcpp::executors::SingleThreadedExecutor executor;
  executor.add_node(node->get_node_base_interface());
  executor.spin();
  rclcpp::shutdown();
  return 0;
}
