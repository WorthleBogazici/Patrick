<?xml version="1.0" encoding="UTF-8"?>
<!--
  Patrick Robot SRDF — MoveIt2 semantic robot description
  ========================================================
  Generated for patrick.urdf.xacro (does NOT redefine links/joints — pulls
  them from the URDF).

  Planning groups:
    - arm            : Joint1..Joint4  (4-DOF positioning, tip = target_cube_ee)
    - gripper        : Joint5R         (parallel-jaw; Joint5L mimics)

  Named states:
    - home   : arm at SW-defined home pose (θ1=π/4, θ2=0, θ3=π/2, θ4=0)
    - stowed : compact stowed pose for driving
    - open   : gripper open
    - closed : gripper closed
-->
<robot name="patrick">

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  Planning Groups                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- arm group defined as a kinematic CHAIN so MoveIt's group tip link
       is arm_tool0 (the TCP at the gripper). Defining the group by
       individual joints would leave the tip at Link5 and put the
       interactive goal marker on the wrist instead of between the jaws. -->
  <group name="arm">
    <chain base_link="base_link" tip_link="arm_tool0"/>
  </group>

  <group name="gripper">
    <joint name="Joint5R"/>
  </group>

  <!-- End-effector declaration: the "gripper" group is the EE of the "arm".
       parent_link = arm_tool0 (virtual TCP at the gripper tip, fixed to
       Link6R) so the interactive goal marker appears between the jaws. -->
  <end_effector name="patrick_gripper"
                parent_link="arm_tool0"
                group="gripper"
                parent_group="arm"/>

  <!-- Virtual joint so MoveIt knows the arm base attaches to the world -->
  <virtual_joint name="world_to_base"
                 type="planar"
                 parent_frame="odom"
                 child_link="base_footprint"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  Named States                                                          -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group_state name="home" group="arm">
    <joint name="Joint1" value="0.7854"/>   <!-- π/4 -->
    <joint name="Joint2" value="0.0"/>
    <joint name="Joint3" value="1.5708"/>   <!-- π/2 -->
    <joint name="Joint4" value="0.0"/>
  </group_state>

  <group_state name="stowed" group="arm">
    <joint name="Joint1" value="0.0"/>
    <joint name="Joint2" value="-1.2"/>
    <joint name="Joint3" value="1.2"/>
    <joint name="Joint4" value="0.0"/>
  </group_state>

  <group_state name="ready" group="arm">
    <joint name="Joint1" value="0.0"/>
    <joint name="Joint2" value="0.0"/>
    <joint name="Joint3" value="0.0"/>
    <joint name="Joint4" value="0.0"/>
  </group_state>

  <group_state name="open" group="gripper">
    <joint name="Joint5R" value="-0.39006"/>
  </group_state>

  <group_state name="closed" group="gripper">
    <joint name="Joint5R" value="0.07565"/>
  </group_state>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  Passive (mimic) Joints                                                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <passive_joint name="Joint5L"/>

  <!-- Wheels are not part of any planning group -->
  <passive_joint name="wheel_left_joint"/>
  <passive_joint name="wheel_right_joint"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  Disable Collisions                                                    -->
  <!--                                                                        -->
  <!--  Pairs in the arm's own kinematic chain never collide with each other  -->
  <!--  during normal motion; we also disable arm-vs-base-platform collisions -->
  <!--  since the arm is mounted on top and can't reach the base geometry.    -->
  <!--                                                                        -->
  <!--  Re-run the MoveIt Setup Assistant if you change the URDF to refresh   -->
  <!--  this table for the full robot (kobuki + stack + camera).              -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Adjacent links -->
  <disable_collisions link1="Link1" link2="Link2" reason="Adjacent"/>
  <disable_collisions link1="Link2" link2="Link3" reason="Adjacent"/>
  <disable_collisions link1="Link3" link2="Link4" reason="Adjacent"/>
  <disable_collisions link1="Link4" link2="Link5" reason="Adjacent"/>
  <disable_collisions link1="Link5" link2="Link6R" reason="Adjacent"/>
  <disable_collisions link1="Link5" link2="Link6L" reason="Adjacent"/>
  <disable_collisions link1="Link6R" link2="Link6L" reason="Default"/>
  <disable_collisions link1="Link6R" link2="target_cube_ee" reason="Adjacent"/>


  <!-- Arm vs kobuki/stack/camera auto-generated disable list. -->
  <!-- The arm is mounted on the stack top plate; it physically cannot
       reach any base / camera / pole link during normal motion, so we
       disable every arm-vs-base pair to keep MoveIt from flagging the
       whole robot as in self-collision. -->
  <disable_collisions link1="Link1" link2="base_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="base_footprint" reason="Never"/>
  <disable_collisions link1="Link1" link2="caster_back_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="caster_front_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="cliff_sensor_front_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="cliff_sensor_left_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="cliff_sensor_right_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="gyro_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="plate_bottom_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="plate_middle_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="plate_top_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="wheel_left_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="wheel_right_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_0_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_1_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_2_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_3_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_4_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_bottom_5_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_kinect_0_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_kinect_1_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_middle_0_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_middle_1_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_middle_2_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_middle_3_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_top_0_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_top_1_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_top_2_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="pole_top_3_link" reason="Never"/>
  <disable_collisions link1="Link1" link2="zed2_baro_link" reason="Never"/>
