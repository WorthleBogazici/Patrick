<?xml version="1.0"?>
<robot name="patrick" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ========================================================= -->
  <!--                   Parameters                               -->
  <!-- ========================================================= -->
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="use_fake_hardware" default="false"/>

  <xacro:property name="use_sim" value="$(arg use_sim)"/>
  <xacro:property name="use_fake_hardware" value="$(arg use_fake_hardware)"/>

  <!-- Mesh path prefix (resolved to absolute file:// URI at xacro time) -->
  <xacro:property name="mesh_path" value="file://$(find patrick_main)/meshes"/>

  <!-- Kobuki dimensions -->
  <xacro:property name="base_radius" value="0.178"/>
  <xacro:property name="base_height" value="0.051"/>
  <xacro:property name="base_z_offset" value="0.0505"/>
  <xacro:property name="wheel_radius" value="0.035"/>
  <xacro:property name="wheel_width" value="0.021"/>
  <xacro:property name="wheel_separation" value="0.230"/>
  <xacro:property name="caster_radius" value="0.012"/>

  <!-- ========================================================= -->
  <!--                   Kobuki Base                              -->
  <!-- ========================================================= -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/kobuki/main_body.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_z_offset}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${base_height}" radius="${base_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.01 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.041656" ixy="0.0" ixz="0.0"
               iyy="0.041656" iyz="0.0" izz="0.076563"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0102" rpy="0 0 0"/>
  </joint>

  <!-- Left wheel -->
  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/kobuki/wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 ${wheel_separation/2} 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right wheel -->
  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/kobuki/wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 ${-wheel_separation/2} 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front caster -->
  <link name="caster_front_link">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin xyz="0.115 0.0 0.003" rpy="0 0 0"/>
  </joint>

  <!-- Back caster -->
  <link name="caster_back_link">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.135 0.0 0.003" rpy="0 0 0"/>
  </joint>

  <!-- Gyro -->
  <link name="gyro_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="gyro_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gyro_link"/>
    <origin xyz="0.056 0.062 0.0202" rpy="0 0 0"/>
  </joint>

  <!-- Cliff sensors -->
  <link name="cliff_sensor_front_link">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="cliff_sensor_front_joint" type="fixed">
    <parent link="base_link"/><child link="cliff_sensor_front_link"/>
    <origin xyz="0.156 0.0 0.0214" rpy="0 ${pi/2} 0"/>
  </joint>

  <link name="cliff_sensor_left_link">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="cliff_sensor_left_joint" type="fixed">
    <parent link="base_link"/><child link="cliff_sensor_left_link"/>
    <origin xyz="0.08734 0.13601 0.0214" rpy="0 ${pi/2} 0"/>
  </joint>

  <link name="cliff_sensor_right_link">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="cliff_sensor_right_joint" type="fixed">
    <parent link="base_link"/><child link="cliff_sensor_right_link"/>
    <origin xyz="0.08734 -0.13601 0.0214" rpy="0 ${pi/2} 0"/>
  </joint>

  <!-- ========================================================= -->
  <!--             TurtleBot Stack (simplified circles)           -->
  <!-- ========================================================= -->
  <xacro:macro name="stack_plate" params="name parent z_offset">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_path}/turtlebot_stack/plate_0_logo.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.006" radius="0.170"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${parent}_to_${name}" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="0 0 ${z_offset}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- Rotated mount for the TurtleBot stack (180 deg yaw) -->
  <link name="stack_mount_link">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="base_link_to_stack_mount" type="fixed">
    <parent link="base_link"/>
    <child link="stack_mount_link"/>
    <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
  </joint>

  <!-- Standoff placeholders (simplified as cylindrical links) -->
  <xacro:macro name="standoff" params="name parent x y z length">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <geometry><cylinder length="${length}" radius="0.006"/></geometry>
        <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
      </visual>
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${parent}_to_${name}" type="fixed">
      <parent link="${parent}"/><child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- Spacers -->
  <xacro:standoff name="spacer_0_link" parent="stack_mount_link" x="0.120" y="0.082" z="0.051" length="0.003"/>
  <xacro:standoff name="spacer_1_link" parent="stack_mount_link" x="0.055" y="0.120" z="0.051" length="0.003"/>
  <xacro:standoff name="spacer_2_link" parent="stack_mount_link" x="0.120" y="-0.082" z="0.051" length="0.003"/>
  <xacro:standoff name="spacer_3_link" parent="stack_mount_link" x="0.055" y="-0.120" z="0.051" length="0.003"/>

  <!-- 2-inch standoffs -->
  <xacro:standoff name="standoff_2in_0_link" parent="stack_mount_link" x="0.120" y="0.082" z="0.054" length="0.0508"/>
  <xacro:standoff name="standoff_2in_1_link" parent="stack_mount_link" x="0.055" y="0.120" z="0.054" length="0.0508"/>
  <xacro:standoff name="standoff_2in_2_link" parent="stack_mount_link" x="0.120" y="-0.082" z="0.054" length="0.0508"/>
  <xacro:standoff name="standoff_2in_3_link" parent="stack_mount_link" x="0.055" y="-0.120" z="0.054" length="0.0508"/>

  <!-- Plates -->
  <xacro:stack_plate name="plate_0_link" parent="stack_mount_link" z_offset="0.1076"/>
  <xacro:stack_plate name="plate_1_link" parent="plate_0_link" z_offset="0.0508"/>

  <!-- 2-inch upper standoffs -->
  <xacro:standoff name="standoff_2in_4_link" parent="standoff_2in_0_link" x="0" y="0" z="0.0572" length="0.0508"/>
  <xacro:standoff name="standoff_2in_5_link" parent="standoff_2in_1_link" x="0" y="0" z="0.0572" length="0.0508"/>
  <xacro:standoff name="standoff_2in_6_link" parent="standoff_2in_2_link" x="0" y="0" z="0.0572" length="0.0508"/>
  <xacro:standoff name="standoff_2in_7_link" parent="standoff_2in_3_link" x="0" y="0" z="0.0572" length="0.0508"/>

  <xacro:stack_plate name="plate_2_link" parent="plate_1_link" z_offset="0.0508"/>

  <!-- 8-inch standoffs -->
  <xacro:standoff name="standoff_8in_0_link" parent="standoff_2in_4_link" x="0" y="0" z="0.0572" length="0.2032"/>
  <xacro:standoff name="standoff_8in_1_link" parent="standoff_2in_5_link" x="0" y="0" z="0.0572" length="0.2032"/>
  <xacro:standoff name="standoff_8in_2_link" parent="standoff_2in_6_link" x="0" y="0" z="0.0572" length="0.2032"/>
  <xacro:standoff name="standoff_8in_3_link" parent="standoff_2in_7_link" x="0" y="0" z="0.0572" length="0.2032"/>

  <xacro:stack_plate name="plate_3_link" parent="plate_2_link" z_offset="0.2032"/>

  <!-- Kinect standoffs -->
  <xacro:standoff name="standoff_kinect_0_link" parent="plate_2_link" x="-0.1024" y="0.098" z="0.006" length="0.008"/>
  <xacro:standoff name="standoff_kinect_1_link" parent="plate_2_link" x="-0.1024" y="-0.098" z="0.006" length="0.008"/>

  <!-- ========================================================= -->
  <!--                 Camera (Kinect depth sensor)               -->
  <!-- ========================================================= -->
  <!-- Matches ROS1 turtlebot kinect.urdf.xacro layout:
       camera_rgb_frame -> camera_link (mesh visual)
                        -> camera_rgb_optical_frame
                        -> camera_depth_frame -> camera_depth_optical_frame -->

  <xacro:property name="cam_px" value="-0.087"/>
  <xacro:property name="cam_py" value="-0.0125"/>
  <xacro:property name="cam_pz" value="0.0"/>

  <joint name="camera_rgb_joint" type="fixed">
    <origin xyz="${cam_px} ${cam_py} ${cam_pz}" rpy="0 0 0"/>
    <parent link="plate_3_link"/>
    <child link="camera_rgb_frame"/>
  </joint>
  <link name="camera_rgb_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="camera_rgb_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    <parent link="camera_rgb_frame"/>
    <child link="camera_rgb_optical_frame"/>
  </joint>
  <link name="camera_rgb_optical_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="-0.031 0.0125 -0.016" rpy="0 0 0"/>
    <parent link="camera_rgb_frame"/>
    <child link="camera_link"/>
  </joint>
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
      <geometry><mesh filename="${mesh_path}/kinect.dae"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.07271 0.27794 0.073"/></geometry>
    </collision>
    <inertial>
      <mass value="0.564"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.003881243" ixy="0.0" ixz="0.0"
               iyy="0.000498940" iyz="0.0" izz="0.003879257"/>
    </inertial>
  </link>

  <joint name="camera_depth_joint" type="fixed">
    <origin xyz="0 0.025 0" rpy="0 0 0"/>
    <parent link="camera_rgb_frame"/>
    <child link="camera_depth_frame"/>
  </joint>
  <link name="camera_depth_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="camera_depth_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
  </joint>
  <link name="camera_depth_optical_frame">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <!-- ========================================================= -->
  <!--           Arm mounted on TurtleBot stack                   -->
  <!-- ========================================================= -->
  <link name="arm_mount_link">
    <inertial><mass value="0.001"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="stack_top_to_arm_mount" type="fixed">
    <parent link="plate_3_link"/>
    <child link="arm_mount_link"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
  </joint>
  <joint name="arm_mount_on_stack" type="fixed">
    <parent link="arm_mount_link"/>
    <child link="Link1"/>
    <origin xyz="0.10 0.10 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!--                    ARM LINKS                               -->
  <!-- ========================================================= -->

  <!-- Link1 (base of arm) -->
  <link name="Link1">
    <inertial>
      <origin xyz="-0.061896 -0.020892 0.069546" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="5.186E-04" ixy="7.307E-05" ixz="-1.239E-05"
               iyy="7.194E-04" iyz="-1.654E-05" izz="5.177E-04"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link1.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.06 -0.02 0.07" rpy="0 0 0"/>
      <geometry><box size="0.10 0.06 0.14"/></geometry>
    </collision>
  </link>

  <!-- Link2 -->
  <link name="Link2">
    <inertial>
      <origin xyz="1.51E-08 0.010107 0.028392" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="2.291E-04" ixy="1.805E-09" ixz="9.404E-11"
               iyy="2.110E-04" iyz="-1.486E-05" izz="3.907E-04"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link2.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0.01 0.04" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.08"/></geometry>
    </collision>
  </link>

  <joint name="Joint1" type="revolute">
    <origin xyz="-0.079116 0.022 0.08412" rpy="1.5708 0 3.1416"/>
    <parent link="Link1"/><child link="Link2"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="5.0" friction="0.5"/>
    <limit lower="-1.57079632679" upper="1.57079632679" effort="50" velocity="2"/>
  </joint>

  <!-- Link3 -->
  <link name="Link3">
    <inertial>
      <origin xyz="-0.089748 -0.018544 0.10562" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.550E-05" ixy="-3.576E-06" ixz="1.173E-06"
               iyy="1.591E-04" iyz="4.734E-06" izz="1.594E-04"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link3.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.09 -0.02 0.09" rpy="0 0 0"/>
      <geometry><box size="0.18 0.05 0.10"/></geometry>
    </collision>
  </link>

  <joint name="Joint2" type="revolute">
    <origin xyz="0 0 0.083271" rpy="1.5708 0 -3.1416"/>
    <parent link="Link2"/><child link="Link3"/>
    <axis xyz="0 0 -1"/>
    <dynamics damping="5.0" friction="0.5"/>
    <limit lower="-1.57079632679" upper="1.57079632679" effort="50" velocity="2"/>
  </joint>

  <!-- Link4 -->
  <link name="Link4">
    <inertial>
      <origin xyz="0.068509 -0.0027606 0.032156" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1.724E-05" ixy="1.717E-06" ixz="2.220E-06"
               iyy="6.675E-05" iyz="-3.955E-08" izz="7.291E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link4.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.07 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.14 0.04 0.06"/></geometry>
    </collision>
  </link>

  <joint name="Joint3" type="revolute">
    <origin xyz="-0.18 0 0.08918" rpy="1.5708 0 3.1416"/>
    <parent link="Link3"/><child link="Link4"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="5.0" friction="0.5"/>
    <limit lower="-1.57079632679" upper="1.57079632679" effort="50" velocity="2"/>
  </joint>

  <!-- Link5 -->
  <link name="Link5">
    <inertial>
      <origin xyz="-0.0037369 -0.00012065 0.17675" rpy="0 0 0"/>
      <mass value="0.025"/>
      <inertia ixx="9.724E-06" ixy="1.040E-07" ixz="-7.656E-08"
               iyy="1.003E-05" iyz="4.008E-09" izz="1.365E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link5.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.20"/></geometry>
    </collision>
  </link>

  <joint name="Joint4" type="revolute">
    <origin xyz="0 0.00039942 0.0332" rpy="1.5708 0 1.5708"/>
    <parent link="Link4"/><child link="Link5"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="3.0" friction="0.5"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="2"/>
  </joint>

  <!-- Link6R (right gripper finger) -->
  <link name="Link6R">
    <inertial>
      <origin xyz="0.0060906 0.033827 -0.0045" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="7.914E-06" ixy="4.660E-06" ixz="1.228E-20"
               iyy="4.532E-06" iyz="-1.909E-20" izz="1.054E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link6R.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.006 0.03 -0.005" rpy="0 0 0"/>
      <geometry><box size="0.02 0.07 0.01"/></geometry>
    </collision>
  </link>

  <joint name="Joint5R" type="revolute">
    <origin xyz="0 0.034628 0.1976" rpy="1.5708 0 1.5708"/>
    <parent link="Link5"/><child link="Link6R"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="2.0" friction="0.3"/>
    <limit lower="-0.393" upper="0.393" effort="50" velocity="2"/>
  </joint>

  <!-- Link6L (left gripper finger) -->
  <link name="Link6L">
    <inertial>
      <origin xyz="-0.0052518 0.033968 -0.0045" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="7.681E-06" ixy="-4.738E-06" ixz="1.365E-20"
               iyy="4.765E-06" iyz="1.994E-20" izz="1.054E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_path}/Link6L.STL"/></geometry>
      <material name="arm_grey"><color rgba="0.79216 0.81961 0.93333 1"/></material>
    </visual>
    <collision>
      <origin xyz="-0.005 0.03 -0.005" rpy="0 0 0"/>
      <geometry><box size="0.02 0.07 0.01"/></geometry>
    </collision>
  </link>

  <joint name="Joint5L" type="revolute">
    <origin xyz="0 -0.034628 0.1976" rpy="1.5708 0 1.5708"/>
    <parent link="Link5"/><child link="Link6L"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="2.0" friction="0.3"/>
    <limit lower="-0.393" upper="0.393" effort="50" velocity="2"/>
  </joint>

  <!-- End-Effector target cube -->
  <link name="target_cube_ee">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1.7e-08" ixy="0.0" ixz="0.0"
               iyy="1.7e-08" iyz="0.0" izz="1.7e-08"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
      <material name="ee_red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <joint name="link6_to_target_cube" type="revolute">
    <origin xyz="-0.03463 0.02250 -0.0004" rpy="0 0 0"/>
    <parent link="Link6R"/><child link="target_cube_ee"/>
    <limit lower="0.0" upper="0.0" effort="0" velocity="0"/>
  </joint>

  <!-- ========================================================= -->
  <!--              ros2_control hardware interface                -->
  <!-- ========================================================= -->
  <ros2_control name="patrick_ros2_control" type="system">
    <xacro:if value="${use_sim}">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
    </xacro:if>
    <xacro:unless value="${use_sim}">
      <xacro:if value="${use_fake_hardware}">
        <hardware>
          <plugin>mock_components/GenericSystem</plugin>
        </hardware>
      </xacro:if>
      <xacro:unless value="${use_fake_hardware}">
        <hardware>
          <plugin>mock_components/GenericSystem</plugin>
        </hardware>
      </xacro:unless>
    </xacro:unless>

    <!-- Diff drive wheels -->
    <joint name="wheel_left_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel_right_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Arm joints -->
    <joint name="Joint1">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="Joint2">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="Joint3">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="Joint4">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="Joint5R">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="Joint5L">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ========================================================= -->
  <!--              Gazebo Harmonic specifics                      -->
  <!-- ========================================================= -->
  <xacro:if value="${use_sim}">
    <!-- gz_ros2_control plugin -->
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find patrick_main)/config/patrick_controllers.yaml</parameters>
      </plugin>
    </gazebo>

    <!-- Depth camera sensor (Gazebo Harmonic) -->
    <gazebo reference="camera_link">
      <sensor name="depth_camera" type="depth_camera">
        <always_on>true</always_on>
        <update_rate>20</update_rate>
        <topic>depth_camera</topic>
        <camera>
          <horizontal_fov>1.047197</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>8.0</far>
          </clip>
        </camera>
      </sensor>
    </gazebo>

    <!-- Gazebo visual properties -->
    <gazebo reference="Link1">
      <visual><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link2">
      <visual><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link3">
      <visual><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link4">
      <visual><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link5">
      <visual><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link6R">
      <visual><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="Link6L">
      <visual><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
    </gazebo>
    <gazebo reference="target_cube_ee">
      <visual><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
    </gazebo>

    <!-- Caster friction -->
    <gazebo reference="caster_front_link">
      <mu1>0.0</mu1><mu2>0.0</mu2>
    </gazebo>
    <gazebo reference="caster_back_link">
      <mu1>0.0</mu1><mu2>0.0</mu2>
    </gazebo>
  </xacro:if>

</robot>
